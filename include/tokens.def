/* tokens.def — MiniC 终结符主表（X-Macro 单点维护）
 * TOKEN(枚举名, ID, 词法 dump 显示名)
 * 被 common_defs.h、token_names.cpp、SeuYacc/token_registry.inl 包含
 */
