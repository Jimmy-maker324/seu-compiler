TOKEN(T_CASE,         259, "case")
TOKEN(T_CHAR,         260, "char")
TOKEN(T_CONTINUE,     261, "continue")
TOKEN(T_DEFAULT,      262, "default")
TOKEN(T_DOUBLE,       263, "double")
TOKEN(T_ELSE,         264, "else")
TOKEN(T_FLOAT,        265, "float")
TOKEN(T_FOR,          266, "for")
TOKEN(T_IF,           267, "if")
TOKEN(T_INT,          268, "int")
TOKEN(T_RETURN,       269, "return")
TOKEN(T_STRUCT,       270, "struct")
TOKEN(T_SWITCH,       271, "switch")
TOKEN(T_UNION,        272, "union")
TOKEN(T_VOID,         273, "void")
TOKEN(T_WHILE,        274, "while")
TOKEN(T_IDENTIFIER,   275, "IDENTIFIER")
TOKEN(T_CONSTANT,     276, "CONSTANT")
TOKEN(T_STRING_LITERAL, 277, "STRING")
TOKEN(T_FLOAT_CONSTANT, 278, "FLOAT")
TOKEN(T_PTR_OP,       279, "->")
