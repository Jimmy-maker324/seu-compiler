# Doxyfile for Seu Compiler（第七版）
# Usage: gen_docs.bat  或  doxygen config\Doxyfile（在项目根目录执行）
# Output: docs/html/index.html

PROJECT_NAME           = "Seu 编译器（第七版）"
PROJECT_BRIEF          = "东南大学编译原理专题实践 — 词法/语法生成器与 C 子集前端"
PROJECT_NUMBER         = "7.0"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = Chinese

# 只扫描手写源码，排除自动生成的大文件
INPUT                  = README.md \
                         include \
                         Frontend \
                         SeuLex \
                         SeuYacc \
                         grammar \
                         examples
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h \
                         *.cpp \
                         *.y \
                         *.l \
                         *.md
RECURSIVE              = YES
EXCLUDE                = generated \
                         *.o \
                         *.exe
EXCLUDE_PATTERNS       = generated/*

# C++ 项目
OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO

# 从 /** */ 中提取 @file @class @brief 等
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO

# 源码浏览
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# HTML 输出
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO

# 不生成其他格式（可按需开启）
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# 类图需要 Graphviz 的 dot 在 PATH 中
HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = png
INTERACTIVE_SVG        = NO
DOT_GRAPH_MAX_NODES    = 80
MAX_DOT_GRAPH_DEPTH    = 2

# 中文注释
ALWAYS_DETAILED_SEC    = NO
AUTOLINK_SUPPORT       = YES
